[Unit]
Description=FTDI to CRSF bridge
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=__APP_USER__
Group=__APP_GROUP__
SupplementaryGroups=dialout
WorkingDirectory=__PROJECT_ROOT__
ExecStart=__PROJECT_ROOT__/build-linux/tdi_reader __CONFIG_PATH__
Restart=always
RestartSec=2
NoNewPrivileges=true

[Install]
WantedBy=multi-user.target
